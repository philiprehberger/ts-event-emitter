{
  "name": "@philiprehberger/event-emitter",
  "version": "0.3.1",
  "description": "Tiny, fully type-safe event emitter for Node, browser, and edge runtimes",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "test": "node --test src/__tests__/index.test.mjs"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  },
  "keywords": [
    "events",
    "emitter",
    "typed",
    "type-safe",
    "pubsub",
    "lightweight"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/philiprehberger/ts-event-emitter.git"
  },
  "homepage": "https://github.com/philiprehberger/ts-event-emitter#readme",
  "bugs": {
    "url": "https://github.com/philiprehberger/ts-event-emitter/issues"
  },
  "author": "Philip Rehberger",
  "engines": {
    "node": ">=18.0.0"
  },
  "sideEffects": false
}
